# AI Brain — UK · config.toml
# Generated by setup.sh. Customize as needed.

[jurisdiction]
country = "UK"
citation_format = "OSCOLA 4th ed."                   # OSCOLA 4th ed. for UK citations
court_hierarchy = "../uk/_court_hierarchy.json"       # path to a JSON map of courts
bar_rules = "../uk/_bar_rules.md"                     # path to bar-rules markdown (BSB Handbook · SRA Code)
timezone = "Europe/London"                            # BST-aware (DST handling)

[paths]
statute_corpus = "../uk/_statute_corpus/"
drafting_corpus = "../uk/_drafting_data/"
audit_log_dir = "~/.ailawfirm_uk/audit_logs/"
matter_root = "~/.ailawfirm_uk/matters/"

[llm]
provider = "claude"                                    # v0.1 only supports claude
# In v0.3+: "openai" · "gemini_paid" · "ollama" · "byom"
